{
	"schemaVersion": 1,
	"id": "icsys",
	"version": "${version}",
	"name": "I Can Show Your Speed",
	"description": "Displays your character's real-time movement speed (blocks/second) as a clean HUD overlay. Toggle with H key.",
	"authors": [
		"Murqin"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/icsys",
		"sources": "https://github.com/Murqin/icsys",
		"issues": "https://github.com/Murqin/icsys/issues"
	},
	"license": "MIT",
	"icon": "assets/icsys/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			{
				"value": "com.icsys.ICanShowYourSpeedClient",
				"adapter": "kotlin"
			}
		],
		"modmenu": [
			"com.icsys.integration.ModMenuIntegration"
		]
	},
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": ">=0.141.3",
		"fabric-language-kotlin": ">=1.13.9"
	},
	"suggests": {
		"modmenu": "*"
	}
}